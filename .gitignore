# Rust build artifacts
/target/
/tugrust/target/
**/*.rs.bk
Cargo.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# macOS
.DS_Store

# Xcode
*.xcuserstate
*.xcscmblueprint
*.xccheckout
xcuserdata/
*.xcworkspace/xcuserdata/

# Test artifacts
*.log

# Real-session corpus (harvested locally; session content never reaches git)
/tests/app-test/corpus/manifest.json
/tests/app-test/corpus/snapshots/

# project files
git-commit-message.txt
aside

# Tug worktrees
.tug/
.tugtree/

# Tug local runtime artifacts (per-user runtime state now lives out of the
# repo under <data_dir>/Tug/projects/<slug>/ — see `tugutil state-dir`)
.tugtool/step-artifacts/
.tugtool/deck-settings.json
.tugtool/.session

node_modules/

# Frontend build output
tugdeck/dist/

# Distribution artifacts produced by tugrust/scripts/build-app.sh land in
# products/ (tracked via products/.gitkeep so the dir persists). The DMGs
# themselves are ignored — ~90MB per build, useless in git.
/products/Tug.dmg
/products/TugNightly.dmg
/build/

# Static tmux build cache (tugrust/scripts/fetch-tmux.sh).
/.tmux-build/

# dmgbuild lives in a pinned, isolated venv created by
# tugrust/scripts/dmg/ensure-dmgbuild.sh; never checked in.
/.build-tools/
