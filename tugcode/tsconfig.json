{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@tugproto/*": ["../tugproto/src/*"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "probe*.ts"]
}
